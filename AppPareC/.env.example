# Pare Carrito - Example environment variables
# Copy to .env for local use, or use an EnvironmentFile on the VPS.

# Server
PORT=3000

# Google Sheets
SPREADSHEET_ID=
SHEET_NAME=Pedidos

# Google service account credentials (choose ONE approach)
# Preferred for deployments: paste the JSON contents.
GOOGLE_KEY_JSON=

# Alternative: base64 of the service-account JSON
# GOOGLE_KEY_BASE64=

# Legacy/Local: path to json file on disk (recommended: keep it outside git)
# Example: GOOGLE_KEYFILE=pare-carrito-486901-147a8be85a05.json
# GOOGLE_KEYFILE=

# Optional Postgres persistence (best-effort; app works without DB)
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME
# PGSSLMODE=require
